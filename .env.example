# Supabase (from Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: npm run storage:backup — comma-separated bucket names (default: portraits,profile-pictures)
# STORAGE_BACKUP_BUCKETS=portraits,profile-pictures

# Database (from Supabase Dashboard → Settings → Database → Connection string)
# Used by npm run db:backup (pg_dump). Prefer DIRECT_URL (port 5432) for full dumps.
DATABASE_URL=
# Direct connection (port 5432) — recommended for backups and migrations
DIRECT_URL=

# E2E visual baselines (TASK-385 / DEV-003) — run npm run e2e:provision after setting email/password
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
# Optional overrides (defaults match tests/visual/e2e-seed-manifest.json after provision)
E2E_TEST_CHARACTER_ID=
E2E_TEST_CAMPAIGN_ID=
